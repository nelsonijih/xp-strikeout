{
  "name": "xp-strikeout",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "dev:api": "pnpm --filter @xp/api dev",
    "dev:game": "pnpm --filter @xp/game dev",
    "bots": "pnpm --filter @xp/bots start",
    "compose:up": "docker compose -f infra/docker-compose.yml up --build",
    "compose:bots": "docker compose -f infra/docker-compose.yml --profile bots up --build"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
