# XP StrikeOut — environment variable reference.
# COMMIT THIS FILE with placeholders only. Copy to `.env` (gitignored) for local dev.
# For deployed envs, set each value in the platform's secret store — see architecture §14.1
# for which store owns which key.
#
# Legend:
#   [public]    safe to expose to the browser (NEXT_PUBLIC_*)
#   [secret]    server-only — NEVER in client bundles or committed
#   [gen]       you generate this yourself
#   [dashboard] configured in a provider dashboard, not read from here

# ───────────────────────────────────────────────────────────────
# Supabase — Supabase → Project Settings → API
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co       # [public]  → Vercel + local
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>                         # [public]  → Vercel + local
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>                     # [secret]  → Fly(api,game) + CI + local
SUPABASE_JWT_SECRET=<jwt-secret>                                 # [secret]  → Fly(api) + local

# Google OAuth — [dashboard] paste these into Supabase → Auth → Providers → Google,
# NOT into the app. Shown here only so you know they exist.
# GOOGLE_OAUTH_CLIENT_ID=<from Google Cloud Console>
# GOOGLE_OAUTH_CLIENT_SECRET=<from Google Cloud Console>

# ───────────────────────────────────────────────────────────────
# Client (play.xparena.net) — → Vercel env
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GAME_WS_URL=wss://game.xparena.net                   # local: ws://localhost:2567
NEXT_PUBLIC_API_URL=https://api.xparena.net                     # local: http://localhost:8080
NEXT_PUBLIC_AUTH_REDIRECT=https://play.xparena.net/auth/callback # local: http://localhost:3000/auth/callback
SUPABASE_COOKIE_DOMAIN=.xparena.net                             # local: leave empty
NEXT_PUBLIC_SENTRY_DSN=<sentry-dsn>                             # [public] → Vercel + Fly
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX                      # [public] → Vercel

# ───────────────────────────────────────────────────────────────
# api.xparena.net — → Fly(api) secrets   (local values shown)
# ───────────────────────────────────────────────────────────────
PORT=8080
DATABASE_URL=postgres://xp:xp@localhost:5432/xp_strikeout       # [secret] prod: Supabase Postgres
REDIS_URL=redis://localhost:6379                               # [secret] prod: Upstash URL
JOIN_TICKET_SECRET=change-me-openssl-rand-hex-32               # [gen][secret] MUST match game
JOIN_TICKET_TTL_SECONDS=60
JOIN_TICKET_SKEW_SECONDS=30
PAYSTACK_SECRET_KEY=sk_test_xxx                               # [secret] test key for dev
PAYSTACK_WEBHOOK_SECRET=whsec_test                           # [secret]
DEV_AUTH_BYPASS=true                                          # [dev-only] MUST be false/absent in prod
# ^ The service refuses to boot if DEV_AUTH_BYPASS is set while NODE_ENV=production (§16 fail-closed guard).

# ───────────────────────────────────────────────────────────────
# game.xparena.net — → Fly(game) secrets
# (JOIN_TICKET_SECRET, REDIS_URL, SUPABASE_SERVICE_ROLE_KEY reused from above)
# ───────────────────────────────────────────────────────────────
GAME_PORT=2567
FLY_REGION=jnb                                                # non-secret config
